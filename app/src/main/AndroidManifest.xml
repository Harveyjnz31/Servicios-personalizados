<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.servihub">

    <application
        android:allowBackup="true"
        android:icon="@android:mipmap/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:mipmap/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.ServiHub">

        <activity
            android:name=".ui.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ProfileDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.EditProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ServicesListActivity"
            android:exported="false"
            android:label="@string/title_services_list" />

        <activity
            android:name=".ui.RequestsListActivity"
            android:exported="false"
            android:label="Bolsa de Trabajo" />

        <activity
            android:name=".ui.PostRequestActivity"
            android:exported="false"
            android:label="Publicar Solicitud" />

        <activity
            android:name=".ui.ProfessionalDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.ServiHub" />

        <activity
            android:name=".ui.ChatActivity"
            android:exported="false"
            android:label="Chat" />

    </application>

</manifest>